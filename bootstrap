#!/bin/zsh

export XDG_CACHE_HOME="$HOME/.cache"
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_STATE_HOME="$HOME/.local/state"

source utilities

# Xcode Command Line Tools
# ========================
print_title "Xcode Command Line Tools"
xcode-select -p >/dev/null 2>&1 \
  && print_message "Xcode Command Line Tools already installed" \
  || { print_message "Xcode Command Line Tools not installed. Run: xcode-select --install"; exit 1; }

# Homebrew
# ========
print_title "Homebrew"
[ "$(uname -m)" = "arm64" ] && brew_path=/opt/homebrew/bin/brew || brew_path=/usr/local/bin/brew
[ -f "$brew_path" ] \
  && print_message "Homebrew already installed" \
  || /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

eval "$($brew_path shellenv)"
brew bundle

# GitHub SSH Keys
# ===============
print_title "GitHub SSH Keys"
setup_github_ssh_keys

# Dotfiles
# ========
print_title "Dotfiles"
yadm status >/dev/null 2>&1 \
  && print_message "Dotfiles already cloned" \
  || yadm clone git@github.com:caiwilliamson/dotfiles.git

# mise
# ====
print_title "mise"
mise install
eval "$(mise activate zsh)"

# Shell
# =====
print_title "Shell"
allow_shell "$(which fish)"
allow_shell "$(which zsh)"
[ "$SHELL" = "$(which fish)" ] \
  && print_message "Shell already set to fish" \
  || chsh -s "$(which fish)"

# Rails
# =====
print_title "Rails"
[ "$(gem list '^rails$' -i)" = "true" ] \
  && print_message "Rails already installed" \
  || gem install rails

# PostgreSQL
# ==========
print_title "PostgreSQL"
for i in $(seq 1 10); do pg_isready -q && break; sleep 1; done
pg_isready -q || { printf "PostgreSQL failed to start\n"; exit 1; }
createdb 2>/dev/null \
  && print_message "Default database created" \
  || print_message "Default database already exists"

# macOS Settings
# ==============
print_title "macOS Settings"
defaults write com.apple.Terminal ShowLineMarks -int 0
defaults write com.apple.TimeMachine DoNotOfferNewDisksForBackup -bool true
chflags hidden "$HOME/Music" "$HOME/Movies" "$HOME/Pictures" "$HOME/Public"
print_message "macOS settings applied"
